# ==================== OKX API ====================
# 从 OKX 后台获取，需要有读取和交易权限
OKX_API_KEY=your_api_key_here
OKX_SECRET=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# ==================== 通知渠道配置 ====================
# 至少配置一个通知渠道

# 企业微信机器人（推荐）
# 获取方式：企业微信群聊 → 添加机器人 → 复制 Webhook
WECHAT_WEBHOOK=

# 钉钉机器人
# 获取方式：钉钉群聊 → 智能群助手 → 添加机器人 → 关键词填"行情"
DINGTALK_WEBHOOK=

# Server酱（微信推送）
# 获取方式：https://sct.ftqq.com/
SERVERCHAN_KEY=

# Qmsg酱（QQ消息推送）
# 获取方式：https://qmsg.zendee.cn/
QMSG_KEY=
QMSG_QQ=

# Gmail 邮件通知
# 使用方法：
# 1. 开启 Gmail 两步验证
# 2. 访问 https://myaccount.google.com/apppasswords 生成应用专用密码
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_TO=

# Telegram Bot
# 获取方式：找 @BotFather 创建机器人，获取 Token 和 Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==================== 监控参数 ====================

# 持仓跌幅告警阈值（不含杠杆，小数形式）
POSITION_LOSS_THRESHOLD=0.01

# 监控频率（秒）
PRICE_CHECK_INTERVAL=60
POSITION_CHECK_INTERVAL=30
ORDER_CHECK_INTERVAL=10
SIGNAL_CHECK_INTERVAL=300

# 金叉死叉参数
EMA_FAST_PERIOD=12
EMA_SLOW_PERIOD=26

# 形态识别参数
PATTERN_LOOKBACK=20

# 监控的交易对（留空则监控全部 USDT 永续合约）
# 格式：BTC-USDT-SWAP,ETH-USDT-SWAP,SOL-USDT-SWAP
WATCH_SYMBOLS=

# 排除的交易对
EXCLUDE_SYMBOLS=

# 通知冷却时间（秒）- 防止重复通知
NOTIFY_COOLDOWN=300

# ==================== 功能开关 ====================

ENABLE_POSITION_MONITOR=true
ENABLE_ORDER_MONITOR=true
ENABLE_SIGNAL_MONITOR=true

# 通知开关
NOTIFY_POSITION_LOSS=true
NOTIFY_ORDER_FILLED=true
NOTIFY_GOLDEN_CROSS=true
NOTIFY_DEATH_CROSS=true
NOTIFY_PATTERN_UPTREND=true
